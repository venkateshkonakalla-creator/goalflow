rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    // Validates that an existing document's userId field matches the caller
    function isDocOwner(res) {
      return res == null || !('userId' in res.data) || request.auth.uid == res.data.userId;
    }
    // Validates that an incoming write's userId field matches the caller
    function isWriteOwner() {
      return isOwner(request.resource.data.userId);
    }

    // ── /users/{userId} ───────────────────────────────────────────────────
    match /users/{userId} {
      allow read, update, delete: if isAuth() && isOwner(userId);
      allow create: if isAuth() && isOwner(userId);

      match /usage/{docId} {
        allow read, write: if isAuth() && isOwner(userId);
      }
    }

    // ── /goals/{goalId} ───────────────────────────────────────────────────
    match /goals/{goalId} {
      allow read, update, delete: if isAuth() && isDocOwner(resource);
      allow create: if isAuth() && isWriteOwner();
    }

    // ── /expenses/{expenseId} ─────────────────────────────────────────────
    match /expenses/{expenseId} {
      allow read, update, delete: if isAuth() && isDocOwner(resource);
      allow create: if isAuth() && isWriteOwner();
    }

    // ── /income/{incomeId} ────────────────────────────────────────────────
    match /income/{incomeId} {
      allow read, update, delete: if isAuth() && isDocOwner(resource);
      allow create: if isAuth() && isWriteOwner();
    }

    // ── /allocations/{allocId} ────────────────────────────────────────────
    match /allocations/{allocId} {
      allow read, update, delete: if isAuth() && isDocOwner(resource);
      allow create: if isAuth() && isWriteOwner();
    }

    // ── /monthly_plans/{planId} ──────────────────────────────────────────
    match /monthly_plans/{planId} {
      allow read, update, delete: if isAuth() && isDocOwner(resource);
      allow create: if isAuth() && isWriteOwner();
    }

    // ── /monthly_summaries/{summaryId} ──────────────────────────────────
    match /monthly_summaries/{summaryId} {
      allow read, update, delete: if isAuth() && isDocOwner(resource);
      allow create: if isAuth() && isWriteOwner();
    }

    // ── /pending_contributions/{pendingId} ─────────────────────────────
    match /pending_contributions/{pendingId} {
      allow read, update, delete: if isAuth() && isDocOwner(resource);
      allow create: if isAuth() && isWriteOwner();
    }

    // ── /ad_events/{eventId} ─────────────────────────────────────────────
    // Ad events are create-only; users cannot tamper with records once written.
    match /ad_events/{eventId} {
      allow read: if isAuth() && isDocOwner(resource);
      allow create: if isAuth() && isWriteOwner();
      allow update, delete: if false;  // immutable
    }

    // ── /user_ad_state/{userId} ───────────────────────────────────────────
    // Each user has a single doc keyed by their own uid.
    match /user_ad_state/{userId} {
      allow read, write: if isAuth() && isOwner(userId);
    }

    // ── /feedback/{feedbackId} ────────────────────────────────────────────
    match /feedback/{feedbackId} {
      allow read: if isAuth() && isDocOwner(resource);
      allow create: if isAuth() && isWriteOwner();
      allow update, delete: if false;  // immutable
    }

    // ── /contact_messages/{messageId} ──────────────────────────────────────
    match /contact_messages/{messageId} {
      allow create: if request.resource.data.userId == null || (isAuth() && request.resource.data.userId == request.auth.uid);
      allow read, update, delete: if false;  // immutable & write-only
    }
  }
}
